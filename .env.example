# Optional Build Doctor provider review. Deterministic diagnosis works without this.
ENABLE_LLM_ENRICHMENT=false
LLM_PROVIDER=mock
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_TITLE=Build Doctor
ALLOW_PAID_LLM_MODELS=false

# Shared evidence persistence. The apps fall back to deterministic mode without these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=
